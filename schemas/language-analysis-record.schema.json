{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socios-linux.dev/nlplab/language-analysis-record.schema.json",
  "title": "LanguageAnalysisRecord",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "nlplab.socios-linux.dev/v1"
    },
    "kind": {
      "const": "LanguageAnalysisRecord"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "createdBy"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "createdBy": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": [
        "adapter",
        "algorithmFamily",
        "taskContract",
        "inputRef",
        "pipelineOrModelRef",
        "outputs",
        "metrics",
        "policy",
        "evidenceRefs"
      ],
      "properties": {
        "adapter": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1}
          },
          "additionalProperties": true
        },
        "algorithmFamily": {
          "enum": [
            "basic-primitives",
            "advanced-primitives",
            "rule-techniques",
            "classical-ml",
            "neural-nlp",
            "transformers",
            "foundation-language-services",
            "retrieval-bridge",
            "governance-bridge"
          ]
        },
        "taskContract": {"type": "string", "minLength": 1},
        "inputRef": {"type": "string", "minLength": 1},
        "pipelineOrModelRef": {"type": "string", "minLength": 1},
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": {"type": "string", "minLength": 1},
              "value": {},
              "startChar": {"type": "integer", "minimum": 0},
              "endChar": {"type": "integer", "minimum": 0},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1}
            },
            "additionalProperties": true
          }
        },
        "metrics": {
          "type": "object",
          "required": ["latencyMs", "memoryMb"],
          "properties": {
            "latencyMs": {"type": "number", "minimum": 0},
            "memoryMb": {"type": "number", "minimum": 0}
          },
          "additionalProperties": true
        },
        "policy": {
          "type": "object",
          "required": ["decision", "sensitivityCeiling"],
          "properties": {
            "decision": {"type": "string", "minLength": 1},
            "sensitivityCeiling": {"type": "string", "minLength": 1}
          },
          "additionalProperties": true
        },
        "evidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
